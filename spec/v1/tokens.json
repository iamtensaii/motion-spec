{
  "$schema": "https://design-tokens.org/schema/v1",
  "motion-spec": {
    "$description": "motion-spec v1 — semantic animation tokens (W3C DTCG compatible)",
    "$version": "1.0.0",

    "duration": {
      "$description": "Named duration scale",
      "immediate":  { "$value": "100ms",  "$type": "duration" },
      "fast":       { "$value": "150ms",  "$type": "duration" },
      "normal":     { "$value": "250ms",  "$type": "duration" },
      "deliberate": { "$value": "350ms",  "$type": "duration" },
      "slow":       { "$value": "500ms",  "$type": "duration" },
      "cinematic":  { "$value": "700ms",  "$type": "duration" }
    },

    "easing": {
      "$description": "Named easing curves",
      "arrive":     { "$value": [0.0, 0.0, 0.2, 1.0], "$type": "cubicBezier", "$description": "Decelerate on arrival — ease-out family" },
      "depart":     { "$value": [0.4, 0.0, 1.0, 1.0], "$type": "cubicBezier", "$description": "Accelerate on departure — ease-in family" },
      "move":       { "$value": [0.4, 0.0, 0.2, 1.0], "$type": "cubicBezier", "$description": "Standard move — ease-in-out family" },
      "overshoot":  { "$value": [0.34, 1.56, 0.64, 1.0], "$type": "cubicBezier", "$description": "Spring-like overshoot for feedback/celebration" },
      "linear":     { "$value": [0.0, 0.0, 1.0, 1.0], "$type": "cubicBezier", "$description": "Constant rate — loops and progress" }
    },

    "entrance": {
      "default": {
        "duration":   { "$value": "{motion-spec.duration.normal}" },
        "easing":     { "$value": "{motion-spec.easing.arrive}" },
        "translateY": { "$value": "8px",  "$description": "Start offset — element travels up on entry" },
        "opacity":    { "$value": "0→1",  "$description": "Fade in" }
      },
      "focus": {
        "duration":   { "$value": "{motion-spec.duration.deliberate}" },
        "easing":     { "$value": "{motion-spec.easing.arrive}" },
        "translateY": { "$value": "12px" },
        "scale":      { "$value": "0.97→1" },
        "opacity":    { "$value": "0→1" }
      },
      "hero": {
        "duration":   { "$value": "{motion-spec.duration.cinematic}" },
        "easing":     { "$value": "{motion-spec.easing.arrive}" },
        "translateY": { "$value": "24px" },
        "scale":      { "$value": "0.95→1" },
        "opacity":    { "$value": "0→1" }
      },
      "subtle": {
        "duration":   { "$value": "{motion-spec.duration.fast}" },
        "easing":     { "$value": "{motion-spec.easing.arrive}" },
        "translateY": { "$value": "4px" },
        "opacity":    { "$value": "0→1" }
      },
      "immediate": {
        "duration":   { "$value": "{motion-spec.duration.immediate}" },
        "easing":     { "$value": "{motion-spec.easing.arrive}" },
        "opacity":    { "$value": "0→1" }
      }
    },

    "exit": {
      "default": {
        "duration":   { "$value": "{motion-spec.duration.fast}" },
        "easing":     { "$value": "{motion-spec.easing.depart}" },
        "translateY": { "$value": "0→-8px" },
        "opacity":    { "$value": "1→0" }
      },
      "dismiss": {
        "duration":   { "$value": "{motion-spec.duration.normal}" },
        "easing":     { "$value": "{motion-spec.easing.depart}" },
        "scale":      { "$value": "1→0.95" },
        "opacity":    { "$value": "1→0" }
      },
      "replace": {
        "duration":   { "$value": "{motion-spec.duration.deliberate}" },
        "easing":     { "$value": "{motion-spec.easing.move}" },
        "translateX": { "$value": "0→-24px" },
        "opacity":    { "$value": "1→0" }
      },
      "immediate": {
        "duration":   { "$value": "{motion-spec.duration.immediate}" },
        "easing":     { "$value": "{motion-spec.easing.linear}" },
        "opacity":    { "$value": "1→0" }
      }
    },

    "feedback": {
      "success": {
        "duration":   { "$value": "{motion-spec.duration.slow}" },
        "easing":     { "$value": "{motion-spec.easing.overshoot}" },
        "scale":      { "$value": "0.9→1.05→1" },
        "opacity":    { "$value": "0→1" }
      },
      "error": {
        "duration":   { "$value": "{motion-spec.duration.normal}" },
        "easing":     { "$value": "{motion-spec.easing.overshoot}" },
        "translateX": { "$value": "0→-6px→6px→-4px→4px→0", "$description": "Horizontal shake" }
      },
      "warning": {
        "duration":   { "$value": "{motion-spec.duration.deliberate}" },
        "easing":     { "$value": "{motion-spec.easing.arrive}" },
        "translateY": { "$value": "4px→0" },
        "opacity":    { "$value": "0→1" }
      },
      "loading": {
        "duration":   { "$value": "1200ms" },
        "easing":     { "$value": "{motion-spec.easing.linear}" },
        "iteration":  { "$value": "infinite" }
      },
      "confirm": {
        "duration":   { "$value": "{motion-spec.duration.fast}" },
        "easing":     { "$value": "{motion-spec.easing.overshoot}" },
        "scale":      { "$value": "1→0.94→1" }
      }
    },

    "navigation": {
      "forward": {
        "duration":   { "$value": "{motion-spec.duration.deliberate}" },
        "easing":     { "$value": "{motion-spec.easing.move}" },
        "outgoing":   { "translateX": { "$value": "0→-30%" }, "opacity": { "$value": "1→0" } },
        "incoming":   { "translateX": { "$value": "30%→0" },  "opacity": { "$value": "0→1" } }
      },
      "back": {
        "duration":   { "$value": "{motion-spec.duration.deliberate}" },
        "easing":     { "$value": "{motion-spec.easing.move}" },
        "outgoing":   { "translateX": { "$value": "0→30%" },  "opacity": { "$value": "1→0" } },
        "incoming":   { "translateX": { "$value": "-30%→0" }, "opacity": { "$value": "0→1" } }
      },
      "lateral": {
        "duration":   { "$value": "{motion-spec.duration.normal}" },
        "easing":     { "$value": "{motion-spec.easing.move}" },
        "opacity":    { "$value": "0→1" }
      },
      "modal": {
        "duration":   { "$value": "{motion-spec.duration.deliberate}" },
        "easing":     { "$value": "{motion-spec.easing.arrive}" },
        "translateY": { "$value": "32px→0" },
        "scale":      { "$value": "0.96→1" },
        "opacity":    { "$value": "0→1" }
      },
      "dismiss": {
        "duration":   { "$value": "{motion-spec.duration.normal}" },
        "easing":     { "$value": "{motion-spec.easing.depart}" },
        "translateY": { "$value": "0→48px" },
        "opacity":    { "$value": "1→0" }
      }
    },

    "stagger": {
      "list":    { "itemDelay": { "$value": "40ms" }, "maxDelay": { "$value": "400ms" } },
      "grid":    { "itemDelay": { "$value": "30ms" }, "maxDelay": { "$value": "500ms" } },
      "cascade": { "itemDelay": { "$value": "60ms" }, "maxDelay": { "$value": "400ms" } },
      "random":  { "itemDelay": { "$value": "80ms" }, "maxDelay": { "$value": "600ms" } }
    },

    "loading": {
      "skeleton": {
        "duration":   { "$value": "2000ms" },
        "easing":     { "$value": "{motion-spec.easing.linear}" },
        "opacityFrom":{ "$value": "0.5" },
        "opacityTo":  { "$value": "1.0" },
        "iteration":  { "$value": "infinite" }
      },
      "pulse": {
        "duration":   { "$value": "1500ms" },
        "easing":     { "$value": "{motion-spec.easing.linear}" },
        "opacityFrom":{ "$value": "0.4" },
        "opacityTo":  { "$value": "1.0" },
        "iteration":  { "$value": "infinite" }
      }
    },

    "celebration": {
      "milestone": {
        "duration":   { "$value": "{motion-spec.duration.cinematic}" },
        "easing":     { "$value": "{motion-spec.easing.overshoot}" },
        "scale":      { "$value": "0.5→1.1→1.0" },
        "opacity":    { "$value": "0→1" }
      },
      "reward": {
        "duration":   { "$value": "{motion-spec.duration.slow}" },
        "easing":     { "$value": "{motion-spec.easing.overshoot}" },
        "scale":      { "$value": "0.8→1.15→1.0" },
        "opacity":    { "$value": "0→1" }
      },
      "subtle": {
        "duration":   { "$value": "{motion-spec.duration.fast}" },
        "easing":     { "$value": "{motion-spec.easing.overshoot}" },
        "scale":      { "$value": "1→1.08→1.0" }
      }
    },

    "reducedMotion": {
      "$description": "Override values when prefers-reduced-motion: reduce",
      "maxDuration":  { "$value": "150ms" },
      "allowedProperties": { "$value": ["opacity"] },
      "$comment": "Strip all transforms; use opacity transitions only"
    }
  }
}
